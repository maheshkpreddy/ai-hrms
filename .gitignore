# =============================================================================
# AI-HRMS — Comprehensive .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
bun.lock

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
/.next/
/out/

# -----------------------------------------------------------------------------
# Production / Build
# -----------------------------------------------------------------------------
/build
/dist
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env*.local
.env.production
.env.staging
.env.test

# Keep the example template
!.env.example

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.db
*.db-journal
*.db-wal
*.db-shm
/prisma/migrations/
!/prisma/migrations/migration_lock.toml

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.history/

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Debug & Logs
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun-debug.log*
*.log
dev.log
dev.out.log
server.log

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
/coverage
/.nyc_output
test-results/
playwright-report/
.playwright/

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
next-env.d.ts

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pem
*.cache
.local/
.claude
.z-ai-config
.zscripts/
prompt
/skills/
/mini-services/*/node_modules/
upload/

# -----------------------------------------------------------------------------
# Temp & Generated
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
