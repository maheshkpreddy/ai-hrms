generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== MULTI-TENANT CORE ====================

model Company {
  id                  String   @id @default(cuid())
  name                String
  legalName           String?
  code                String   @unique
  gstVat              String?
  panTanCin           String?
  registrationNumber  String?
  industry            String?
  logo                String?
  domain              String?
  address             String?
  country             String?
  state               String?
  city                String?
  currency            String   @default("USD")
  timezone            String   @default("UTC")
  payrollCycle        String?
  financialYear       String?
  defaultLanguage     String?
  status              String   @default("active")
  parentId            String?
  parent              Company?  @relation("CompanyHierarchy", fields: [parentId], references: [id])
  children            Company[] @relation("CompanyHierarchy")
  branches    Branch[]
  departments Department[]
  employees   Employee[]
  users       User[]
  jobs        Job[]
  clients     Client[]
  vendors     Vendor[]
  leavePolicies LeavePolicy[]
  payrollStructures PayrollStructure[]
  surveys     Survey[]
  workflowDefs WorkflowDefinition[]
  shifts      Shift[]
  projects    Project[]
  tasks       Task[]
  helpdeskTickets HelpdeskTicket[]
  companyPolicies CompanyPolicy[]
  requisitions ManpowerRequisition[]
  members     CompanyMember[]
  officeLocations OfficeLocation[]
  meetings    Meeting[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  code      String
  address   String?
  city      String?
  state     String?
  country   String?
  isActive  Boolean  @default(true)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  employees Employee[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id          String   @id @default(cuid())
  name        String
  code        String
  description String?
  isActive    Boolean  @default(true)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  parentId    String?
  parent      Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DeptHierarchy")
  employees   Employee[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== USER & AUTH ====================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  avatar        String?
  role          String   @default("employee")
  isActive      Boolean  @default(true)
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id])
  employee      Employee?
  lastLogin     DateTime?
  notifications Notification[]
  auditLogs     AuditLog[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==================== EMPLOYEE CORE ====================

model Employee {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  firstName       String
  lastName        String
  email           String   @unique
  phone           String?
  avatar          String?
  dateOfBirth     DateTime?
  gender          String?
  maritalStatus   String?
  nationality     String?
  address         String?
  city            String?
  state           String?
  country         String?
  zipCode         String?
  emergencyContact String?
  emergencyPhone  String?
  designation     String
  jobTitle        String?
  employmentType  String   @default("full-time")
  status          String   @default("active")
  joiningDate     DateTime
  exitDate        DateTime?
  probationEnd    DateTime?
  reportingManagerId String?
  reportingManager   Employee?  @relation("ReportingMatrix", fields: [reportingManagerId], references: [id])
  directReports      Employee[] @relation("ReportingMatrix")
  approvedLeaves     Leave[]    @relation("LeaveApprovals")
  approvedExpenses   ExpenseClaim[] @relation("ExpenseApprovals")
  approvedTravel     TravelRequest[] @relation("TravelApprovals")
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  branchId        String?
  branch          Branch?  @relation(fields: [branchId], references: [id])
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id])
  attendance      Attendance[]
  leaves          Leave[]
  payrollRecords  PayrollRecord[]
  goals           Goal[]
  assetAllocations AssetAllocation[]
  expenseClaims   ExpenseClaim[]
  travelRequests  TravelRequest[]
  learningRecords LearningRecord[]
  tickets         Ticket[]
  onboardingTasks OnboardingTask[]
  documents       Document[]
  reviewsGiven    PerformanceReview[] @relation("Reviewer")
  reviewsReceived PerformanceReview[] @relation("Reviewee")
  alumniRecord    AlumniRecord?
  shiftMembers    ShiftMember[]
  projectMembers  ProjectMember[]
  taskAssignments TaskAssignment[]
  taskComments    TaskComment[]
  performances    Performance[]
  employeeSkills  EmployeeSkill[]
  timesheets      Timesheet[]
  companyMembers  CompanyMember[]        @relation("EmployeeCompanyMembers")
  meetingInvitations MeetingInvitation[]  @relation("EmployeeMeetingInvitations")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== RECRUITMENT ====================

model Job {
  id              String   @id @default(cuid())
  title           String
  description     String?
  requirements    String?
  department      String?
  location        String?
  employmentType  String?
  experienceMin   Int?
  experienceMax   Int?
  salaryMin       Float?
  salaryMax       Float?
  status          String   @default("draft")
  priority        String   @default("medium")
  positions       Int      @default(1)
  filledPositions Int      @default(0)
  postedDate      DateTime?
  closingDate     DateTime?
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  candidates      Candidate[]
  interviews      Interview[]
  aiInterviews    AIInterview[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Candidate {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  phone           String?
  resume          String?
  currentCompany  String?
  currentTitle    String?
  experience      Int?
  expectedSalary  Float?
  noticePeriod    String?
  status          String   @default("applied")
  source          String?
  aiScore         Float?
  skillMatch      Float?
  cultureFitScore Float?
  notes           String?
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id])
  interviews      Interview[]
  aiInterviews    AIInterview[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Interview {
  id            String   @id @default(cuid())
  type          String   @default("technical")
  scheduledAt   DateTime
  duration      Int?
  status        String   @default("scheduled")
  feedback      String?
  rating        Int?
  meetingLink   String?
  aiTranscript  String?
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  jobId         String
  job           Job       @relation(fields: [jobId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AIInterview {
  id                String    @id @default(cuid())
  candidateId       String
  candidate         Candidate @relation(fields: [candidateId], references: [id])
  jobId             String
  job               Job       @relation(fields: [jobId], references: [id])
  status            String    @default("scheduled") // scheduled, in_progress, completed, cancelled
  questions         String    @default("[]")
  responses         String    @default("[]")
  score             Float?
  feedback          String?
  language          String    @default("en")
  rubric            String?
  interviewLink     String?   @unique
  resumeUrl         String?
  cheatingSignals   String?
  cvScore           Float?
  videoTimestamps   String?
  transcript        String?
  duration          Int?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ==================== ATTENDANCE ====================

model Attendance {
  id           String   @id @default(cuid())
  date         DateTime
  checkIn      DateTime?
  checkOut     DateTime?
  breakDuration Int?
  workHours    Float?
  status       String   @default("present")
  source       String   @default("web")
  notes        String?
  gpsLatitude  Float?
  gpsLongitude Float?
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([employeeId, date])
}

// ==================== LEAVE ====================

model LeavePolicy {
  id            String   @id @default(cuid())
  name          String
  type          String
  totalDays     Int
  carryForward  Boolean  @default(false)
  maxCarryDays  Int      @default(0)
  isPaid        Boolean  @default(true)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Leave {
  id          String   @id @default(cuid())
  type        String
  startDate   DateTime
  endDate     DateTime
  totalDays   Float
  reason      String?
  status      String   @default("pending")
  approverComment String?
  approverId  String?
  approver    Employee? @relation("LeaveApprovals", fields: [approverId], references: [id])
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  workflowInstanceId String?
  workflowInstance   WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== PAYROLL ====================

model PayrollStructure {
  id          String   @id @default(cuid())
  name        String
  basicPay    Float
  hra         Float?
  da          Float?
  transportAllowance Float?
  medicalAllowance   Float?
  specialAllowance   Float?
  pfEmployee  Float?
  pfEmployer  Float?
  esiEmployee Float?
  esiEmployer Float?
  taxDeduction Float?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PayrollRecord {
  id              String   @id @default(cuid())
  month           Int
  year            Int
  basicPay        Float
  grossSalary     Float
  totalDeductions Float
  netSalary       Float
  status          String   @default("processed")
  paymentDate     DateTime?
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([employeeId, month, year])
}

// ==================== PERFORMANCE ====================

model Goal {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("individual")
  category    String?
  progress    Int      @default(0)
  status      String   @default("not_started")
  startDate   DateTime
  endDate     DateTime
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReviewCycle {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("annual")
  startDate   DateTime
  endDate     DateTime
  status      String   @default("draft")
  companyId   String
  reviews     PerformanceReview[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PerformanceReview {
  id          String   @id @default(cuid())
  cycleId     String?
  cycle       ReviewCycle? @relation(fields: [cycleId], references: [id])
  reviewerId  String
  reviewer    Employee @relation("Reviewer", fields: [reviewerId], references: [id])
  revieweeId  String
  reviewee    Employee @relation("Reviewee", fields: [revieweeId], references: [id])
  rating      Int
  comments    String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== ASSETS ====================

model AssetAllocation {
  id          String   @id @default(cuid())
  assetType   String
  assetName   String
  assetCode   String?
  serialNumber String?
  allocatedAt DateTime @default(now())
  returnedAt  DateTime?
  status      String   @default("allocated")
  notes       String?
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== TRAVEL & EXPENSE ====================

model TravelRequest {
  id              String   @id @default(cuid())
  purpose         String
  destination     String
  departureDate   DateTime
  returnDate      DateTime
  estimatedCost   Float?
  approvedCost    Float?
  status          String   @default("pending")
  approverComment String?
  approverId      String?
  approver        Employee? @relation("TravelApprovals", fields: [approverId], references: [id])
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  workflowInstanceId String?
  workflowInstance   WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ExpenseClaim {
  id          String   @id @default(cuid())
  type        String
  amount      Float
  description String?
  receipt     String?
  status      String   @default("pending")
  approverComment String?
  approverId  String?
  approver    Employee? @relation("ExpenseApprovals", fields: [approverId], references: [id])
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  workflowInstanceId String?
  workflowInstance   WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== LEARNING ====================

model LearningRecord {
  id          String   @id @default(cuid())
  courseName  String
  provider    String?
  type        String   @default("e_learning")
  status      String   @default("enrolled")
  completedAt DateTime?
  score       Int?
  certificate String?
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== HELPDESK ====================

model Ticket {
  id          String   @id @default(cuid())
  subject     String
  description String?
  category    String
  priority    String   @default("medium")
  status      String   @default("open")
  resolution  String?
  assignedTo  String?
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== CLIENT/VENDOR ECOSYSTEM ====================

model Client {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  clientCompany String?
  industry      String?
  contractStart DateTime?
  contractEnd   DateTime?
  status        String   @default("active")
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Vendor {
  id             String   @id @default(cuid())
  name           String
  email          String?
  phone          String?
  vendorCompany  String?
  serviceType    String?
  status         String   @default("active")
  rating         Float?
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  subVendors     SubVendor[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SubVendor {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  phone           String?
  company         String?
  status          String   @default("active")
  vendorId        String?
  vendor          Vendor?  @relation(fields: [vendorId], references: [id])
  uploadedResumes SubVendorResume[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  type        String   @default("info")
  category    String   @default("general")
  isRead      Boolean  @default(false)
  actionUrl   String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== WORKFLOW ENGINE ====================

model WorkflowDefinition {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("approval")
  entity      String
  description String?
  isActive    Boolean  @default(true)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  steps       WorkflowStepDef[]
  instances   WorkflowInstance[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkflowStepDef {
  id            String   @id @default(cuid())
  name          String
  stepOrder     Int
  approverRole  String?
  approverType  String   @default("role")
  autoApprove   Boolean  @default(false)
  action        String   @default("approve_reject")
  workflowDefId String
  workflowDef   WorkflowDefinition @relation(fields: [workflowDefId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkflowInstance {
  id            String   @id @default(cuid())
  status        String   @default("pending")
  currentStep   Int      @default(0)
  initiatedBy   String
  workflowDefId String
  workflowDef   WorkflowDefinition @relation(fields: [workflowDefId], references: [id])
  steps         WorkflowStepInstance[]
  leaves        Leave[]
  travelRequests TravelRequest[]
  expenseClaims  ExpenseClaim[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkflowStepInstance {
  id            String   @id @default(cuid())
  stepOrder     Int
  status        String   @default("pending")
  actionedBy    String?
  comments      String?
  actedAt       DateTime?
  workflowInstanceId String
  workflowInstance   WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==================== SURVEY & ENGAGEMENT ====================

model Survey {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("pulse")
  status      String   @default("draft")
  startDate   DateTime?
  endDate     DateTime?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  questions   SurveyQuestion[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SurveyQuestion {
  id          String   @id @default(cuid())
  question    String
  type        String   @default("rating")
  options     String?
  required    Boolean  @default(true)
  order       Int      @default(0)
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  responses   SurveyResponse[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SurveyResponse {
  id          String   @id @default(cuid())
  answer      String
  questionId  String
  question    SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  employeeId  String
  createdAt   DateTime @default(now())
}

// ==================== ONBOARDING ====================

model OnboardingTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("general")
  status      String   @default("pending")
  dueDate     DateTime?
  completedAt DateTime?
  assignedTo  String?
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== DOCUMENTS ====================

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("general")
  fileUrl     String?
  status      String   @default("active")
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== SHIFTS ====================

model Shift {
  id          String   @id @default(cuid())
  name        String
  startTime   String
  endTime     String
  breakMinutes Int     @default(30)
  isActive    Boolean  @default(true)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  members     ShiftMember[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShiftMember {
  id          String   @id @default(cuid())
  effectiveDate DateTime
  shiftId     String
  shift       Shift    @relation(fields: [shiftId], references: [id])
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([employeeId, effectiveDate, shiftId])
}

// ==================== ALUMNI ====================

model AlumniRecord {
  id          String   @id @default(cuid())
  exitReason  String?
  rehireEligible Boolean @default(true)
  alumniEmail String?
  joinedAlumniAt DateTime @default(now())
  employeeId  String   @unique
  employee    Employee @relation(fields: [employeeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== COMPLIANCE ====================

model ComplianceItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  dueDate     DateTime?
  status      String   @default("pending")
  assignee    String?
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== PROJECTS ====================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("planning")
  priority    String   @default("medium")
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  progress    Int      @default(0)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdBy   String?
  members     ProjectMember[]
  milestones  ProjectMilestone[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectMember {
  id        String   @id @default(cuid())
  role      String   @default("member")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId String
  employee  Employee @relation(fields: [employeeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, employeeId])
}

model ProjectMilestone {
  id          String   @id @default(cuid())
  name        String
  description String?
  dueDate     DateTime?
  status      String   @default("pending")
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== TASKS ====================

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  priority    String   @default("medium")
  status      String   @default("todo")
  dueDate     DateTime?
  imageUrl    String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdBy   String?
  assignments TaskAssignment[]
  comments    TaskComment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TaskComment {
  id         String   @id @default(cuid())
  content    String
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ==================== HELPDESK (Enhanced) ====================

model HelpdeskTicket {
  id             String   @id @default(cuid())
  ticketId       String   @unique
  requesterId    String?
  requesterType  String   @default("employee")
  category       String
  subCategory    String?
  priority       String   @default("medium")
  subject        String
  description    String?
  attachmentUrl  String?
  assignedAgentId String?
  slaDeadline    DateTime?
  status         String   @default("open")
  resolution     String?
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  comments       HelpdeskTicketComment[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model HelpdeskTicketComment {
  id        String   @id @default(cuid())
  content   String
  ticketId  String
  ticket    HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  employeeId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== PERFORMANCE (Enhanced) ====================

model Performance {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  reviewPeriod  String
  reviewerId    String?
  rating        Int      @default(0)
  objectives    String?
  achievements  String?
  feedback      String?
  selfReview    String?
  goals         String?
  attritionRisk Float    @default(0)
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==================== RBAC ====================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  level       Int      @default(4)
  permissions String?  // JSON string for module permissions
  dashboard   String?  @default("employee")
  menuItems   String?  // JSON string for sidebar menu items
  color       String?  @default("teal")
  companyId   String?
  rolePermissions RolePermission[]
  users       UserRoleAssignment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RolePermission {
  id       String   @id @default(cuid())
  roleId   String
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module   String
  canRead  Boolean  @default(false)
  canWrite Boolean  @default(false)
  canDelete Boolean @default(false)
  canExport Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, module])
}

model UserRoleAssignment {
  id       String   @id @default(cuid())
  roleId   String
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  userId   String
  createdAt DateTime @default(now())
}

// ==================== SKILLS ====================

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?
  description String?
  employeeSkills EmployeeSkill[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmployeeSkill {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id])
  proficiency String  @default("intermediate")
  yearsExp   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, skillId])
}

// ==================== POLICIES ====================

model CompanyPolicy {
  id          String   @id @default(cuid())
  title       String
  content     String?
  category    String?
  version     String?
  effectiveDate DateTime?
  status      String   @default("active")
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== TIMESHEETS ====================

model Timesheet {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  weekStart   DateTime
  weekEnd     DateTime
  totalHours  Float    @default(0)
  status      String   @default("draft")
  approvedBy  String?
  approvedAt  DateTime?
  entries     TimesheetEntry[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, weekStart])
}

model TimesheetEntry {
  id          String   @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  date        DateTime
  hours       Float    @default(0)
  project     String?
  task        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== REQUISITIONS ====================

model ManpowerRequisition {
  id              String   @id @default(cuid())
  title           String
  department      String?
  position        String?
  positionsNeeded Int      @default(1)
  priority        String   @default("medium")
  justification   String?
  status          String   @default("draft")
  requestedBy     String?
  approvedBy      String?
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== SUB-VENDOR RESUMES ====================

model SubVendorResume {
  id              String   @id @default(cuid())
  candidateName   String
  email           String
  phone           String?
  resumeUrl       String?
  skills          String?
  experience      String?
  currentCompany  String?
  expectedSalary  String?
  jobId           String?
  status          String   @default("uploaded")
  subVendorId     String
  subVendor       SubVendor @relation(fields: [subVendorId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== AUDIT ====================

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String?
  details     String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  ipAddress   String?
  module      String?
  employeeId  String?
  createdAt   DateTime @default(now())
}

// ==================== COMPANY MEMBERS ====================

model CompanyMember {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  employeeId  String
  employee    Employee  @relation("EmployeeCompanyMembers", fields: [employeeId], references: [id])
  role        String    @default("employee")
  status      String    @default("approved")
  joinedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([companyId, employeeId])
}

// ==================== OFFICE LOCATIONS ====================

model OfficeLocation {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  address     String?
  latitude    Float
  longitude   Float
  radius      Float    @default(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== MEETINGS ====================

model Meeting {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  title       String
  description String?
  date        DateTime
  startTime   String
  endTime     String?
  location    String?
  meetingType String   @default("in_person")
  status      String   @default("scheduled")
  createdBy   String?
  invitations MeetingInvitation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MeetingInvitation {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation("EmployeeMeetingInvitations", fields: [employeeId], references: [id])
  rsvpStatus  String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([meetingId, employeeId])
}
