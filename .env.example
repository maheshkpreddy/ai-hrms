# =============================================================================
# AI-HRMS Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running the application.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Prisma database connection URL
# For SQLite (default):  file:./dev.db
# For PostgreSQL:        postgresql://user:password@localhost:5432/aihrms?schema=public
# For MySQL:             mysql://user:password@localhost:3306/aihrms
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# NextAuth.js — Authentication
# -----------------------------------------------------------------------------
# Generate a secret:  openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-change-me-in-production"

# The canonical URL of your application (no trailing slash)
# Development:  http://localhost:3000
# Production:   https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# AI Service — z-ai-web-dev-sdk
# -----------------------------------------------------------------------------
# API key for the AI assistant chat feature (z-ai-web-dev-sdk)
ZAI_API_KEY=""

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Node environment: development | production | test
NODE_ENV="development"

# Application port (default: 3000)
PORT="3000"

# -----------------------------------------------------------------------------
# Optional — Email Service (for notifications)
# -----------------------------------------------------------------------------
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="noreply@your-domain.com"

# -----------------------------------------------------------------------------
# Optional — File Storage (for resume uploads, documents, receipts)
# -----------------------------------------------------------------------------
# STORAGE_TYPE="local"                    # local | s3
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET=""

# -----------------------------------------------------------------------------
# Optional — Monitoring & Analytics
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ANALYTICS_ID=""              # e.g., Google Analytics
# SENTRY_DSN=""                            # Sentry error tracking
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# -----------------------------------------------------------------------------
# Optional — Vercel Deployment
# -----------------------------------------------------------------------------
# VERCEL_TOKEN=""
# VERCEL_ORG_ID=""
# VERCEL_PROJECT_ID=""
